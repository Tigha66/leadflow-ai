# LeadFlow AI Environment Variables
# Copy this to .env and fill in your values

# Database
DATABASE_URL="postgresql://user:password@localhost:5432/leadflow?schema=public"

# OpenAI (AI conversations)
OPENAI_API_KEY="sk-..."

# Twilio (SMS/WhatsApp)
TWILIO_ACCOUNT_SID="AC..."
TWILIO_AUTH_TOKEN="..."
TWILIO_PHONE_NUMBER="+1234567890"

# Stripe (Billing)
STRIPE_SECRET_KEY="sk_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
STRIPE_PRICE_ID_STARTER="price_..."
STRIPE_PRICE_ID_GROWTH="price_..."
STRIPE_PRICE_ID_PRO="price_..."

# Google Calendar
GOOGLE_CALENDAR_CLIENT_ID="..."
GOOGLE_CALENDAR_CLIENT_SECRET="..."
GOOGLE_CALENDAR_REDIRECT_URI="http://localhost:3000/api/integrations/google/callback"

# App Settings
NEXT_PUBLIC_APP_NAME="LeadFlow AI"
NEXT_PUBLIC_API_URL="http://localhost:3000/api"
JWT_SECRET="your-jwt-secret-here"

# Email (optional - for notifications)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-app-password"

# Redis (for job queues - optional for MVP)
REDIS_URL="redis://localhost:6379"
